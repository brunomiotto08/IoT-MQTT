# Copie este arquivo para .env e preencha os valores
# Este arquivo é o backend (src/server.js)

# Supabase - URL e chave pública (usadas para validar tokens JWT)
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Supabase - Chave de serviço secreta (acesso admin ao banco)
SUPABASE_SERVICE_KEY=sb_secret_...

# String de conexão direta com o banco de dados (Supabase > Settings > Database)
SUPABASE_CONNECTION_STRING=postgresql://postgres.SEU_PROJETO:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# Broker MQTT
MQTT_HOST=IP_DO_BROKER
MQTT_PORT=1883
MQTT_USER=usuario
MQTT_PASSWORD=senha

# URL do frontend em produção (para configurar CORS corretamente)
FRONTEND_URL=https://seu-app.vercel.app
